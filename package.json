{
  "name": "kavach-workspace",
  "version": "1.0.0-next.35",
  "description": "Drop in security for SvelteKit Apps.",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.10",
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "prepare": "husky",
    "clean": "find . -name node_modules -type d -prune -exec rm -rf '{}' +",
    "test:watch": "NODE_NO_WARNINGS=1 vitest --config config/vitest.config.js",
    "test:ci": "NODE_NO_WARNINGS=1 vitest run --config config/vitest.config.js",
    "coverage": "NODE_NO_WARNINGS=1 vitest run --coverage --config config/vitest.config.js",
    "format": "prettier --config config/.prettierrc --ignore-path config/.prettierignore --write .",
    "lint": "eslint --config config/eslint.config.mjs --fix",
    "lockfile": "bun install",
    "build:all": "find ./packages -type d -depth 1 -exec sh -c 'cd \"{}\" && bun run build' \\;",
    "upgrade:all": "bun update --latest",
    "bump": "bun run lockfile && bumpp --configFilePath config/bump.config.js --no-push",
    "bump:next": "bumpp --configFilePath config/bump.config.js --preid=next --no-push",
    "publish:packages": "find ./packages -type d -depth 1 -exec sh -c 'cd \"{}\" && bun publish' \\;",
    "publish:adapters": "find ./adapters -type d -depth 1 -exec sh -c 'cd \"{}\" && bun publish' \\;",
    "publish:all": "bun run publish:packages && bun run publish:adapters",
    "release": "bun run publish:all"
  },
  "author": "Jerry Thomas<me@jerrythomas.name",
  "license": "MIT",
  "devDependencies": {
    "@jerrythomas/prettier-config": "^1.0.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/ramda": "^0.31.1",
    "@vitest/coverage-v8": "^4.0.18",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.10",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,svelte}": "eslint --config config/eslint.config.mjs --cache --fix",
    "*.{js,svelte,md,json}": "prettier --config config/.prettierrc --write"
  },
  "workspaces": [
    "adapters/*",
    "packages/**",
    "sites/**"
  ],
  "dependencies": {
    "@rokkit/actions": "latest",
    "@rokkit/core": "latest",
    "@rokkit/data": "latest",
    "@rokkit/forms": "latest",
    "@rokkit/icons": "latest",
    "@rokkit/states": "latest",
    "@rokkit/themes": "latest",
    "@rokkit/ui": "latest"
  }
}
