{
  "name": "@kavach/logger",
  "version": "1.0.0-next.27",
  "description": "A logger for use on UI and backend.",
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "keywords": [
    "logger",
    "logging"
  ],
  "main": "index.js",
  "module": "src/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jerrythomas/kavach",
    "directory": "packages/logger"
  },
  "prettier": "@jerrythomas/prettier-config",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "tsc",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:ci": "vitest run",
    "test:ui": "vitest --ui",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "upgrade": "pnpm upgrade --latest && pnpm test:ci",
    "release": "pnpm publish --access public"
  },
  "devDependencies": {
    "@jerrythomas/prettier-config": "^1.0.2",
    "@types/node": "^22.15.3",
    "@vitest/coverage-istanbul": "^3.1.2",
    "@vitest/ui": "~3.1.2",
    "shared-config": "workspace:*",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "3.1.2"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js",
      "svelte": "./src/index.js"
    }
  }
}
