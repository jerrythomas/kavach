{
  "extends": "../../config/tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "allowJs": true,
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["**/spec/**/*", "**/fixtures/**/*", "**/templates/**/*"]
}
