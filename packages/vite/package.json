{
  "name": "@kavach/vite",
  "version": "1.0.0-next.36",
  "description": "Vite plugin for Kavach authentication framework",
  "module": "src/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jerrythomas/kavach",
    "directory": "packages/vite"
  },
  "prettier": "@jerrythomas/prettier-config",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "bun clean && bun tsc --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "build": "bun prepublishOnly",
    "test": "vitest run"
  },
  "files": [
    "src/**/*.js",
    "src/**/*.svelte",
    "src/**/*.ddl",
    "dist/**/*.d.ts",
    "README.md",
    "package.json"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "dependencies": {
    "magicast": "^0.3.5"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT"
}
