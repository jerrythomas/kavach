{
  "name": "@kavach/cli",
  "version": "1.0.0-next.37",
  "description": "CLI for scaffolding Kavach into SvelteKit projects",
  "type": "module",
  "bin": {
    "kavach": "src/index.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./adapters": "./src/adapters.js"
  },
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@kavach/vite": "workspace:*",
    "magicast": "^0.3.5",
    "picocolors": "^1.1.1"
  },
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jerrythomas/kavach",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/**/*.js",
    "README.md",
    "package.json"
  ]
