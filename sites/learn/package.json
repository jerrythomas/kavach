{
  "name": "learn-kavach",
  "version": "1.0.0-next.35",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "prebuild": "rm -rf static/llms && cp -r ../../docs/llms static/",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "npm run test:integration && npm run test:unit",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:integration": "playwright test",
    "test:unit": "vitest"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rokkit/icons": "latest",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.54.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/eslint": "^9.6.1",
    "@unocss/extractor-svelte": "66.6.6",
    "@unocss/reset": "66.6.6",
    "@unocss/vite": "66.6.6",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.10",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "unocss": "66.6.6",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "type": "module",
  "dependencies": {
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/overpass": "^5.2.8",
    "@fontsource/victor-mono": "^5.2.8",
    "@kavach/ui": "workspace:*",
    "@kavach/logger": "workspace:*",
    "@rokkit/actions": "latest",
    "@rokkit/app": "latest",
    "@rokkit/core": "latest",
    "@rokkit/states": "latest",
    "@rokkit/themes": "latest",
    "@rokkit/ui": "latest",
    "@rokkit/unocss": "latest",
    "kavach": "workspace:*"
  }
}
