{
  "name": "demo-kavach",
  "version": "1.0.0-next.37",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "test:e2e:supabase": "KAVACH_ADAPTER=supabase playwright test",
    "test:e2e:firebase": "KAVACH_ADAPTER=firebase playwright test",
    "test:e2e:convex": "KAVACH_ADAPTER=convex playwright test",
    "test:e2e:all": "npm run test:e2e:supabase && npm run test:e2e:firebase && npm run test:e2e:convex",
    "emulators": "bunx firebase emulators:start",
    "convex:dev": "bunx convex dev --local"
  },
  "devDependencies": {
    "@kavach/vite": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.54.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@unocss/extractor-svelte": "66.6.6",
    "@unocss/reset": "66.6.6",
    "@unocss/vite": "66.6.6",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "firebase-tools": "^15.10.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.10",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "unocss": "66.6.6",
    "vite": "^7.3.1"
  },
  "type": "module",
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@kavach/adapter-convex": "workspace:*",
    "@kavach/adapter-firebase": "workspace:*",
    "@kavach/adapter-supabase": "workspace:*",
    "@kavach/logger": "workspace:*",
    "@kavach/ui": "workspace:*",
    "@rokkit/actions": "1.0.0-next.145",
    "@rokkit/app": "1.0.0-next.145",
    "@rokkit/core": "1.0.0-next.145",
    "@rokkit/icons": "1.0.0-next.145",
    "@rokkit/states": "1.0.0-next.145",
    "@rokkit/themes": "1.0.0-next.145",
    "@rokkit/ui": "1.0.0-next.145",
    "@rokkit/unocss": "1.0.0-next.145",
    "@supabase/supabase-js": "^2.99.1",
    "convex": "^1.24.0",
    "firebase": "^10.14.1",
    "kavach": "workspace:*"
  }
}
