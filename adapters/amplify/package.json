{
  "name": "@kavach/adapter-amplify",
  "version": "1.0.0-next.27",
  "description": "Adapter to use amplify with kavach.",
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "main": "index.js",
  "module": "src/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jerrythomas/kavach",
    "directory": "adapters/amplify"
  },
  "prettier": "@jerrythomas/prettier-config",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "tsc",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:ui": "vitest --ui",
    "test": "vitest",
    "bundle": "release-it",
    "upgrade": "pnpm upgrade --latest && pnpm test:ci",
    "release": "pnpm publish --access public"
  },
  "devDependencies": {
    "@jerrythomas/prettier-config": "^1.0.2",
    "@vitest/coverage-istanbul": "^3.1.3",
    "@vitest/ui": "~3.1.3",
    "jsdom": "^26.1.0",
    "shared-config": "workspace:*",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "~3.1.3"
  },
  "dependencies": {
    "@kavach/core": "workspace:*",
    "aws-amplify": "^6.14.4"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./src/index.js",
      "svelte": "./src/index.js"
    }
  }
}
